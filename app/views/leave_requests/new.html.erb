<h1>Apply for Leave</h1>

<% if @leave_request.errors.any? %>
  <div class="error-messages">
    <h3>Please correct the following errors:</h3>
    <ul>
      <% @leave_request.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: @leave_request, local: true) do |f| %>
  <div>
    <%= f.label :start_date %>
    <%= f.date_field :start_date %>
  </div>

  <div>
    <%= f.label :end_date %>
    <%= f.date_field :end_date %>
  </div>

  <div>
    <%= f.label :reason %>
    <%= f.text_area :reason %>
  </div>

  <div>
    <%= f.label :hr_id, "Select HR" %>
    <%= f.select :hr_id, options_from_collection_for_select(@hrs, :id, :email), prompt: "Choose HR Manager" %>
  </div>

  <div>
    <%= f.submit "Submit Leave Request", class: "btn btn-primary" %>
  </div>
<% end %>
